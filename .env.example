# ─────────────────────────────────────────────
#  orchestrateur-llm — Variables d'environnement
#  Copiez en .env et remplissez vos valeurs.
#  Ne jamais commiter .env dans git.
# ─────────────────────────────────────────────

# ── Clés API cloud (obligatoires) ────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
GEMINI_API_KEY=AIza-REPLACE_ME

# ── Modèle local llama-cpp-4 (optionnel) ─────
# Par défaut : sélection automatique selon la RAM
#   ≤  8 Go → Qwen2.5-Coder-3B-Instruct-Q4_K_M.gguf
#   ≤ 24 Go → Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf
#   > 24 Go → Qwen2.5-Coder-14B-Instruct-Q4_K_M.gguf
#
# Pour forcer un modèle spécifique :
# MODEL_REPO=bartowski/Qwen2.5-Coder-3B-Instruct-GGUF
# MODEL_FILE=Qwen2.5-Coder-3B-Instruct-Q4_K_M.gguf

# ── Tuning inférence llama-cpp-4 (optionnel) ─
# LLM_TEMPERATURE=0.2
# LLM_TOP_K=40
# LLM_TOP_P=0.9
# LLM_SEED=42
# LLM_MAX_NEW_TOKENS=0      # 0 = auto depuis la fenêtre de contexte
# LLM_N_CTX=8192
# LLM_N_GPU_LAYERS=999      # 999 = toutes les couches GPU (macOS Metal)
# LLM_N_THREADS=            # vide = détection auto CPU
